#!/usr/bin/env python3

import argparse
import http.server
import os
import shutil
import socket
import socketserver
import struct
import subprocess
import sys
import tempfile
import threading
import time
import unittest
from dataclasses import dataclass, field
from pathlib import Path

STATUS_OK = 0x00
STATUS_NOOP = 0x01
STATUS_ERR = 0x02

REQ_GET = 0x00
REQ_PUT = 0x01
REQ_STOP = 0x03
REQ_INFO = 0x04
REQ_EXISTS = 0x05

PUT_FLAG_OVERWRITE = 0x01

VERSION_FILE = Path(__file__).resolve().parents[2] / "version.txt"
PROJECT_VERSION = VERSION_FILE.read_text(encoding="utf-8").strip()

HOST_U64 = struct.Struct("=Q")
BINARY_PATH: Path | None = None


@dataclass
class ResponseSpec:
    status: int
    body: bytes = b""
    headers: dict[str, str] = field(default_factory=dict)
    omit_content_length: bool = False


@dataclass
class RecordedRequest:
    method: str
    path: str
    body: bytes
    headers: dict[str, str]


@dataclass
class Greeting:
    protocol_version: int
    capabilities: bytes


class ThreadingHttpServer(socketserver.ThreadingMixIn, http.server.HTTPServer):
    daemon_threads = True
    allow_reuse_address = True

    def __init__(self, server_address, routes):
        super().__init__(server_address, StubRequestHandler)
        self.routes = routes
        self.requests: list[RecordedRequest] = []


class StubRequestHandler(http.server.BaseHTTPRequestHandler):
    protocol_version = "HTTP/1.0"

    def do_GET(self):
        self._handle()

    def do_HEAD(self):
        self._handle()

    def do_PUT(self):
        self._handle()

    def log_message(self, _format, *_args):
        pass

    def _handle(self):
        content_length = int(self.headers.get("Content-Length", "0"))
        body = self.rfile.read(content_length) if content_length else b""
        request = RecordedRequest(
            method=self.command,
            path=self.path,
            body=body,
            headers={key: value for key, value in self.headers.items()},
        )
        self.server.requests.append(request)

        route = self.server.routes.get((self.command, self.path))
        if route is None:
            route = ResponseSpec(status=404)

        self.send_response(route.status)
        for key, value in route.headers.items():
            self.send_header(key, value)
        if not route.omit_content_length:
            self.send_header("Content-Length", str(len(route.body)))
        self.end_headers()

        if self.command != "HEAD" and route.body:
            self.wfile.write(route.body)


class StubHttpServer:
    def __init__(self, routes: dict[tuple[str, str], ResponseSpec]):
        self._server = ThreadingHttpServer(("127.0.0.1", 0), routes)
        self._thread = threading.Thread(target=self._server.serve_forever, daemon=True)

    @property
    def base_url(self) -> str:
        return f"http://127.0.0.1:{self._server.server_port}"

    @property
    def requests(self) -> list[RecordedRequest]:
        return self._server.requests

    def __enter__(self):
        self._thread.start()
        return self

    def __exit__(self, exc_type, exc, tb):
        self._server.shutdown()
        self._server.server_close()
        self._thread.join(timeout=5)
        return False


class HelperProcess:
    def __init__(
        self,
        binary: Path,
        base_url: str,
        *,
        attrs: list[tuple[str, str]] | None = None,
    ):
        self._binary = str(binary)
        self._base_url = base_url
        self._attrs = [("layout", "flat")] if attrs is None else attrs
        self._tmpdir = Path(tempfile.mkdtemp(prefix="crsh-it-", dir="/tmp"))
        self._socket_path = self._tmpdir / "helper.sock"
        self._log_path = self._tmpdir / "helper.log"
        self._process: subprocess.Popen | None = None
        self._socket: socket.socket | None = None
        self.greeting: Greeting | None = None

    def __enter__(self):
        env = {
            **os.environ,
            "CRSH_IPC_ENDPOINT": str(self._socket_path),
            "CRSH_URL": self._base_url,
            "CRSH_IDLE_TIMEOUT": "30",
            "CRSH_NUM_ATTR": str(len(self._attrs)),
            "CRSH_LOGFILE": str(self._log_path),
        }
        for index, (key, value) in enumerate(self._attrs):
            env[f"CRSH_ATTR_KEY_{index}"] = key
            env[f"CRSH_ATTR_VALUE_{index}"] = value

        self._process = subprocess.Popen(
            [self._binary],
            env=env,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
        )

        deadline = time.monotonic() + 10
        while time.monotonic() < deadline:
            if self._process.poll() is not None:
                raise AssertionError(
                    self._failure_details("helper exited before binding IPC socket")
                )
            if self._socket_path.exists():
                break
            time.sleep(0.05)
        else:
            raise AssertionError(
                self._failure_details("timed out waiting for IPC socket")
            )

        self._socket = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        while True:
            try:
                self._socket.connect(str(self._socket_path))
                break
            except FileNotFoundError as e:
                if time.monotonic() >= deadline:
                    raise AssertionError(
                        self._failure_details("IPC socket disappeared before connect")
                    ) from e
                time.sleep(0.05)
            except ConnectionRefusedError as e:
                if time.monotonic() >= deadline:
                    raise AssertionError(
                        self._failure_details("timed out connecting to IPC socket")
                    ) from e
                time.sleep(0.05)

        self.greeting = self._read_greeting()
        if self.greeting.protocol_version != 1:
            raise AssertionError("protocol version != 1")
        return self

    def __exit__(self, exc_type, exc, tb):
        try:
            if self._socket is not None:
                try:
                    self.stop()
                except Exception:
                    pass
                self._socket.close()
        finally:
            if self._process is not None:
                try:
                    self._process.wait(timeout=5)
                except subprocess.TimeoutExpired:
                    self._process.kill()
                    self._process.wait(timeout=5)
                if self._process.stdout is not None:
                    self._process.stdout.close()
                if self._process.stderr is not None:
                    self._process.stderr.close()
            shutil.rmtree(self._tmpdir, ignore_errors=True)
        return False

    def exists(self, hex_key: str):
        key = bytes.fromhex(hex_key)
        self._socket.sendall(bytes((REQ_EXISTS, len(key))) + key)
        status = self._recv_exact(1)[0]
        if status == STATUS_OK:
            return (status, bool(self._recv_exact(1)[0]))
        if status == STATUS_ERR:
            return (status, self._read_error_message())
        raise AssertionError(f"unexpected EXISTS status: {status}")

    def get(self, hex_key: str):
        key = bytes.fromhex(hex_key)
        self._socket.sendall(bytes((REQ_GET, len(key))) + key)
        status = self._recv_exact(1)[0]
        if status == STATUS_OK:
            length = HOST_U64.unpack(self._recv_exact(HOST_U64.size))[0]
            payload = self._recv_exact(length)
            return (status, payload)
        if status == STATUS_NOOP:
            return (status, None)
        if status == STATUS_ERR:
            return (status, self._read_error_message())
        raise AssertionError(f"unexpected GET status: {status}")

    def put(self, hex_key: str, payload: bytes, *, overwrite: bool = False):
        key = bytes.fromhex(hex_key)
        flags = PUT_FLAG_OVERWRITE if overwrite else 0
        request = (
            bytes((REQ_PUT, len(key)))
            + key
            + bytes((flags,))
            + HOST_U64.pack(len(payload))
            + payload
        )
        self._socket.sendall(request)
        status = self._recv_exact(1)[0]
        if status == STATUS_ERR:
            return (status, self._read_error_message())
        if status in (STATUS_OK, STATUS_NOOP):
            return (status, None)
        raise AssertionError(f"unexpected PUT status: {status}")

    def info(self):
        self._socket.sendall(bytes((REQ_INFO,)))
        identity = self._read_message()
        diagnostics = [self._read_message() for _ in range(self._recv_exact(1)[0])]
        return (identity, diagnostics)

    def stop(self):
        if self._socket is None:
            return
        self._socket.sendall(bytes((REQ_STOP,)))
        status = self._recv_exact(1)[0]
        if status != STATUS_OK:
            raise AssertionError(f"unexpected STOP status: {status}")

    def _recv_exact(self, size: int) -> bytes:
        buf = bytearray()
        while len(buf) < size:
            chunk = self._socket.recv(size - len(buf))
            if not chunk:
                raise AssertionError(
                    self._failure_details(f"unexpected EOF while reading {size} bytes")
                )
            buf.extend(chunk)
        return bytes(buf)

    def _read_message(self) -> str:
        size = self._recv_exact(1)[0]
        return self._recv_exact(size).decode("utf-8")

    def _read_error_message(self) -> str:
        return self._read_message()

    def _read_greeting(self) -> Greeting:
        protocol_version, num_capabilities = self._recv_exact(2)
        capabilities = self._recv_exact(num_capabilities)
        return Greeting(protocol_version=protocol_version, capabilities=capabilities)

    def _failure_details(self, message: str) -> str:
        details = [message]
        if self._log_path.exists():
            log = self._log_path.read_text(encoding="utf-8", errors="replace")
            details.append(f"helper log:\n{log}")
        if self._process is not None:
            stdout, stderr = (
                self._process.communicate(timeout=0)
                if self._process.poll() is not None
                else ("", "")
            )
            if stdout:
                details.append(f"stdout:\n{stdout}")
            if stderr:
                details.append(f"stderr:\n{stderr}")
        return "\n\n".join(details)


@unittest.skipIf(os.name == "nt", "requires Unix domain sockets")
class StorageHelperIntegrationTest(unittest.TestCase):
    def test_info_returns_identity_and_no_diagnostics(self):
        with (
            StubHttpServer({}) as server,
            HelperProcess(BINARY_PATH, server.base_url) as helper,
        ):
            identity, diagnostics = helper.info()

        self.assertEqual(identity, f"ccache-storage-http-cpp {PROJECT_VERSION}")
        self.assertEqual(diagnostics, [])
        self.assertEqual(server.requests, [])

    def test_info_returns_diagnostics(self):
        with (
            StubHttpServer({}) as server,
            HelperProcess(
                BINARY_PATH,
                server.base_url,
                attrs=[
                    ("layout", "flat"),
                    ("mystery-attr", "value"),
                    ("header", "broken-header"),
                ],
            ) as helper,
        ):
            identity, diagnostics = helper.info()

        self.assertEqual(identity, f"ccache-storage-http-cpp {PROJECT_VERSION}")
        self.assertEqual(
            diagnostics,
            [
                "warning: unknown attribute: mystery-attr",
                'error: invalid header (no "="): broken-header',
            ],
        )
        self.assertEqual(server.requests, [])

    def test_get_with_content_length(self):
        with (
            StubHttpServer(
                {("GET", "/abcd"): ResponseSpec(status=200, body=b"cache-hit")}
            ) as server,
            HelperProcess(BINARY_PATH, server.base_url) as helper,
        ):
            status, payload = helper.get("abcd")

        self.assertEqual(status, STATUS_OK)
        self.assertEqual(payload, b"cache-hit")
        self.assertEqual(
            [(request.method, request.path) for request in server.requests],
            [("GET", "/abcd")],
        )

    def test_get_without_content_length(self):
        routes = {
            ("GET", "/ef01"): ResponseSpec(
                status=200, body=b"streamed-body", omit_content_length=True
            )
        }
        with (
            StubHttpServer(routes) as server,
            HelperProcess(BINARY_PATH, server.base_url) as helper,
        ):
            status, payload = helper.get("ef01")

        self.assertEqual(status, STATUS_OK)
        self.assertEqual(payload, b"streamed-body")
        self.assertEqual(
            [(request.method, request.path) for request in server.requests],
            [("GET", "/ef01")],
        )

    def test_get_not_found_returns_noop(self):
        with (
            StubHttpServer({}) as server,
            HelperProcess(BINARY_PATH, server.base_url) as helper,
        ):
            status, payload = helper.get("beef")

        self.assertEqual(status, STATUS_NOOP)
        self.assertIsNone(payload)
        self.assertEqual(
            [(request.method, request.path) for request in server.requests],
            [("GET", "/beef")],
        )

    def test_get_server_error_returns_error(self):
        with (
            StubHttpServer({("GET", "/dead"): ResponseSpec(status=500)}) as server,
            HelperProcess(BINARY_PATH, server.base_url) as helper,
        ):
            status, error = helper.get("dead")

        self.assertEqual(status, STATUS_ERR)
        self.assertEqual(error, "HTTP 500")
        self.assertEqual(
            [(request.method, request.path) for request in server.requests],
            [("GET", "/dead")],
        )

    def test_exists_returns_true_when_key_exists(self):
        with (
            StubHttpServer({("HEAD", "/babe"): ResponseSpec(status=200)}) as server,
            HelperProcess(BINARY_PATH, server.base_url) as helper,
        ):
            status, exists = helper.exists("babe")

        self.assertEqual(status, STATUS_OK)
        self.assertTrue(exists)
        self.assertEqual(
            [(request.method, request.path) for request in server.requests],
            [("HEAD", "/babe")],
        )

    def test_exists_returns_false_when_key_is_missing(self):
        with (
            StubHttpServer({}) as server,
            HelperProcess(BINARY_PATH, server.base_url) as helper,
        ):
            status, exists = helper.exists("feed")

        self.assertEqual(status, STATUS_OK)
        self.assertFalse(exists)
        self.assertEqual(
            [(request.method, request.path) for request in server.requests],
            [("HEAD", "/feed")],
        )

    def test_put_overwrite_sends_body(self):
        payload = b"new-entry"
        with (
            StubHttpServer({("PUT", "/1234"): ResponseSpec(status=201)}) as server,
            HelperProcess(BINARY_PATH, server.base_url) as helper,
        ):
            status, error = helper.put("1234", payload, overwrite=True)

        self.assertEqual(status, STATUS_OK)
        self.assertIsNone(error)
        self.assertEqual(
            [(request.method, request.path) for request in server.requests],
            [("PUT", "/1234")],
        )
        self.assertEqual(server.requests[0].body, payload)

    def test_put_without_overwrite_checks_head_before_put(self):
        payload = b"write-after-head"
        routes = {
            ("HEAD", "/cafe"): ResponseSpec(status=404),
            ("PUT", "/cafe"): ResponseSpec(status=201),
        }
        with (
            StubHttpServer(routes) as server,
            HelperProcess(BINARY_PATH, server.base_url) as helper,
        ):
            status, error = helper.put("cafe", payload, overwrite=False)

        self.assertEqual(status, STATUS_OK)
        self.assertIsNone(error)
        self.assertEqual(
            [(request.method, request.path) for request in server.requests],
            [("HEAD", "/cafe"), ("PUT", "/cafe")],
        )
        self.assertEqual(server.requests[1].body, payload)

    def test_put_without_overwrite_returns_noop_when_key_exists(self):
        with (
            StubHttpServer({("HEAD", "/face"): ResponseSpec(status=200)}) as server,
            HelperProcess(BINARY_PATH, server.base_url) as helper,
        ):
            status, error = helper.put("face", b"unchanged", overwrite=False)

        self.assertEqual(status, STATUS_NOOP)
        self.assertIsNone(error)
        self.assertEqual(
            [(request.method, request.path) for request in server.requests],
            [("HEAD", "/face")],
        )

    def test_put_head_error_is_reported(self):
        with (
            StubHttpServer({("HEAD", "/f00d"): ResponseSpec(status=500)}) as server,
            HelperProcess(BINARY_PATH, server.base_url) as helper,
        ):
            status, error = helper.put("f00d", b"payload", overwrite=False)

        self.assertEqual(status, STATUS_ERR)
        self.assertEqual(error, "HTTP 500")
        self.assertEqual(
            [(request.method, request.path) for request in server.requests],
            [("HEAD", "/f00d")],
        )

    def test_put_server_error_is_reported(self):
        with (
            StubHttpServer({("PUT", "/aaaa"): ResponseSpec(status=500)}) as server,
            HelperProcess(BINARY_PATH, server.base_url) as helper,
        ):
            status, error = helper.put("aaaa", b"payload", overwrite=True)

        self.assertEqual(status, STATUS_ERR)
        self.assertEqual(error, "HTTP 500")
        self.assertEqual(
            [(request.method, request.path) for request in server.requests],
            [("PUT", "/aaaa")],
        )


if __name__ == "__main__":
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("--binary", required=True)
    args, remaining = parser.parse_known_args()
    BINARY_PATH = Path(args.binary)
    unittest.main(argv=[sys.argv[0], *remaining])
